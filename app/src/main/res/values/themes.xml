<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Plain platform theme (TapGarden uses a bare Activity, no AppCompat).
         Fullscreen + no action bar; the Activity also forces immersive mode. -->
    <style name="Theme.TapGarden" parent="@android:style/Theme.Material.NoActionBar.Fullscreen">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
